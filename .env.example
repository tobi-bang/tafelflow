# --- Supabase (Pflicht für die Web-App) ---
# Projekt: Settings → API (URL + anon public key).
# Lokal: als .env.local kopieren. Vercel: Project → Settings → Environment Variables
#         für Production (und ggf. Preview) setzen, dann Redeploy.
VITE_SUPABASE_URL="https://xxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# Optional: Storage-Bucket für Pictureload (Standard: pictureload). Nur setzen, wenn der Bucket im Dashboard anders heißt.
# VITE_SUPABASE_STORAGE_BUCKET_PICTURELOAD="pictureload"

# Kein Demo-/Offline-Modus: ohne die beiden VITE_*-Variablen startet die App nicht.

# Optional: Basis-URL für absolute Links (falls du sie in Skripten nutzt)
# APP_URL="https://deine-domain.vercel.app"

# Optional: nur für „npm run dev“ mit server.ts – E-Mail-Export (/api/export/email)
# Auf reiner Vercel-Static-Deploy-Variante (nur „vite build“) wird dieser Server nicht genutzt.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=
# EMAIL_PASS=
