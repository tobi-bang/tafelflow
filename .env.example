# Supabase (Project Settings → API) – für .env.local (lokal) und Vercel → Environment Variables
VITE_SUPABASE_URL="https://xxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# Kein Demo-Modus: Es gibt keine VITE_LOCAL_DEMO-Variable in dieser App.

# Optional (nur falls du die GenAI-Features nutzt)
GEMINI_API_KEY=""
APP_URL=""

# Optional: nur für npm run dev mit server.ts – E-Mail-Export (/api/export/email)
# Ohne diese Variablen liefert die API 503 statt Demo-SMTP.
# SMTP_HOST=
# SMTP_PORT=587
# EMAIL_USER=
# EMAIL_PASS=
